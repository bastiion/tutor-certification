{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["cypress", "node"],
    "isolatedModules": true
  },
  "include": ["./**/*.cy.ts", "./support/**/*.ts"]
}
