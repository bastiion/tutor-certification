{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["cypress", "bun-types"],
    "isolatedModules": true
  },
  "include": ["./**/*.cy.ts"]
}
