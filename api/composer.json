{
  "name": "ikwsd/teilnahmebescheinigungen-api",
  "description": "PHP API bootstrap (sessions/certificates planned later)",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.4"
  },
  "require-dev": {
    "pestphp/pest": "^3.8",
    "phpstan/phpstan": "^2.1",
    "phpmailer/phpmailer": "^6.11"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    }
  },
  "scripts": {
    "phpstan": "phpstan analyse",
    "analyse": "@phpstan",
    "test": "pest",
    "test:coverage": "pest --coverage --coverage-html=coverage/html --coverage-clover=coverage/clover.xml",
    "test:coverage-bootstrap": "pest --coverage --coverage-html=coverage/html --coverage-clover=coverage/clover.xml --min=100"
  }
}
