# Copy to `.env` next to `docker-compose.traefik.yml` and adjust.

# GitHub Container Registry image (lowercase), without tag — same as release workflow output.
# Defaults to this repository's GHCR namespace; override if you fork or republish elsewhere.
REGISTRY_IMAGE=ghcr.io/bastiion/tutor-certification

# Must match the Git tag you released (e.g. v0.1.0). The workflow also pushes `latest`.
IMAGE_TAG=v0.1.0

# Public hostname Traefik should route to this service.
DOMAIN=certs.example.org

# Docker network Traefik already uses (external). Create if missing, e.g.:
#   docker network create traefik
TRAEFIK_NETWORK_NAME=traefik

# Optional: disambiguate if you run multiple stacks on one Traefik.
TRAEFIK_ROUTER_NAME=ikwsd-certs

# Traefik entrypoint name (must exist in your static/dynamic Traefik config).
TRAEFIK_ENTRYPOINT=websecure

# ACME / TLS certificate resolver name in Traefik (or remove tls.* labels if terminating TLS elsewhere).
TRAEFIK_CERT_RESOLVER=letsencrypt
