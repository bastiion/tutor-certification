# Copy to `.env` next to `docker-compose.*.yml` and adjust. Generate secrets with the
# production image helper (see deploy/README.md):
#   docker run --rm --entrypoint /usr/local/bin/env-wizard …

# ── Docker image (required for compose) ─────────────────────────────────────
# GitHub Container Registry image (lowercase), without tag — same as release workflow output.
REGISTRY_IMAGE=ghcr.io/bastiion/tutor-certification

# Must match the Git tag you released (e.g. v0.1.0). The workflow also pushes `latest`.
IMAGE_TAG=v0.1.0

# Direct compose only (`docker-compose.direct.yml`): host port mapped to container :8080.
HOST_PORT=8080

# Optional: SQLite file path inside the container (default: /var/www/html/db/certs.sqlite).
# Use e.g. /data/certs.sqlite + volume on /data to persist without hiding db/schema.sql.
# API_SQLITE_PATH=/data/certs.sqlite

# ── Traefik (`docker-compose.traefik.yml` only — ignore for direct compose) ────
# Public hostname the router should match (Host(`...`)).
DOMAIN=certs.example.org

# External Docker network Traefik uses (create if missing, e.g. `docker network create traefik`).
TRAEFIK_NETWORK_NAME=traefik

# Optional: disambiguate if you run multiple stacks on one Traefik.
TRAEFIK_ROUTER_NAME=bastiion-certs

# Traefik entrypoint name (must exist in your Traefik static/dynamic config).
TRAEFIK_ENTRYPOINT=websecure

# ACME / TLS certificate resolver in Traefik (or adjust labels if TLS terminates elsewhere).
TRAEFIK_CERT_RESOLVER=letsencrypt

# ── PHP API (secrets + runtime) ──────────────────────────────────────────────
# libsodium crypto_box keypair 64 bytes (sk||pk), URL-safe Base64 without padding — seals K_course_private for the server.
SERVER_BOX_KEYPAIR_BASE64=REPLACE_WITH_LIBSODIUM_CRYPTO_BOX_KEYPAIR_BASE64URL

# 32-byte HMAC key for enrollment tokens, URL-safe Base64 without padding.
TOKEN_HMAC_KEY_BASE64=REPLACE_WITH_32_RANDOM_BYTES_BASE64URL

# Shared opaque bearer token for tutor routes (POST /api/sessions, POST /api/revocations).
TUTOR_API_TOKEN=REPLACE_WITH_LONG_RANDOM_HEX_OR_PASSWORD

# Tutor inbox where issuance notifications are sent (SMTP configured below).
TUTOR_EMAIL=tutor@example.org

# Public origin used to build enrollment URLs returned by POST /api/sessions (no trailing slash).
PUBLIC_BASE_URL=https://certs.example.org

# Optional; comma-separated browser origins if tutor/participant/verify dev servers call the API cross-origin.
CORS_ALLOWED_ORIGINS=

SMTP_HOST=smtp.example.org
SMTP_PORT=587
MAIL_FROM_ADDRESS=noreply@example.org

# Optional: leave empty for plain SMTP (local relay, Mailpit). Use `tls` (STARTTLS, often 587) or `ssl` (SMTPS, often 465).
SMTP_SECURE=

# Optional: both must be set together for authenticated SMTP.
SMTP_USER=
SMTP_PASSWORD=
