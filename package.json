{
  "name": "ikwsd-certs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": ["apps/*", "packages/*"],
    "catalog": {
      "react": "^19",
      "react-dom": "^19",
      "tailwindcss": "^4.1.11",
      "bun-plugin-tailwind": "^0.1.2",
      "zod": "^4.3.6",
      "typescript": "5.7.3",
      "cypress": "13.17.0",
      "@types/bun": "latest",
      "@types/react": "^19",
      "@types/react-dom": "^19"
    }
  },
  "scripts": {
    "dev": "bun --hot server.ts",
    "start": "NODE_ENV=production bun server.ts",
    "build": "bun run build.ts",
    "typecheck": "tsc --noEmit",
    "cypress": "cypress run",
    "cypress:open": "cypress open",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "composer:backend": "docker compose run --rm --entrypoint composer php install",
    "test:backend": "docker compose run --rm --entrypoint composer php test",
    "test:backend:coverage": "docker compose run --rm --entrypoint composer php test:coverage-bootstrap",
    "analyse:backend": "docker compose run --rm --entrypoint composer php analyse"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "bun-plugin-tailwind": "catalog:",
    "cypress": "catalog:",
    "typescript": "catalog:"
  }
}
